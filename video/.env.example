# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
OUTPUT_ROOT=outputs/jobs
UPLOAD_MAX_MB=800

VLM_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
OPENAI_API_KEY=

# Processing defaults
DEFAULT_SAMPLE_FPS=1.0
DEFAULT_MAX_PEOPLE_PER_FRAME=8
DEFAULT_MIN_PERSON_HEIGHT=80
DEFAULT_YOLO_MODEL=yolov8n.pt
DEFAULT_YOLO_CONF=0.25
CONTACT_SHEET_SIZE=30
TOP_RESULTS=20
CLIP_SECONDS_BEFORE=3
CLIP_SECONDS_AFTER=5
DEDUP_WINDOW_SECONDS=2.5

# Location Breadcrumbs
LOCALIZATION_ENABLED=true
LOCALIZATION_DEFAULT_BEFORE_SEC=60
LOCALIZATION_DEFAULT_AFTER_SEC=60
LOCALIZATION_DEFAULT_SAMPLE_FPS=1.0
LOCALIZATION_MAX_CONTEXT_FRAMES=120
LOCALIZATION_TOP_FRAMES_FOR_VLM=24
LOCALIZATION_TOP_LOCATION_RESULTS=5

OCR_PROVIDER=google_vision
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_ENABLED=true
NOMINATIM_ENABLED=true
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=lost-person-pov-search-mvp/0.1 your-email@example.com
OVERPASS_ENABLED=false
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter

WEB_GROUNDING_PROVIDER=none
GEMINI_WEB_GROUNDING_MODEL=gemini-2.5-flash
OPENAI_WEB_SEARCH_MODEL=gpt-5.1-mini

DEFAULT_EVENT_NAME=Nashik-Trimbakeshwar Simhastha
DEFAULT_EVENT_CITY=Nashik / Trimbakeshwar
DEFAULT_EVENT_COUNTRY=India
DEFAULT_EVENT_CENTER_LAT=19.9696921
DEFAULT_EVENT_CENTER_LNG=73.6616225
DEFAULT_EVENT_RADIUS_M=35000
DEFAULT_EVENT_KEYWORDS=ramkund,godaghat,godavari,panchavati,ganga godavari,ghat,kushawarta,kushavart,kusavarta,trimbak,trimbakeshwar,brahmagiri,godavari source
